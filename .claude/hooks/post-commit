#!/bin/bash
# PIA Post-Commit Hook
# 自动记录提交到 SESSION.md

COMMIT_HASH=$(git rev-parse --short HEAD)
COMMIT_MSG=$(git log -1 --pretty=%B)
COMMIT_AUTHOR=$(git log -1 --pretty=%an)
COMMIT_TIME=$(git log -1 --pretty=%ci)

SESSION_FILE=".claude/memory/SESSION.md"

# 确保 SESSION.md 存在
if [ ! -f "$SESSION_FILE" ]; then
    mkdir -p "$(dirname "$SESSION_FILE")"
    echo "# Session Log" > "$SESSION_FILE"
    echo "" >> "$SESSION_FILE"
    echo "自动记录开发会话中的关键改动。" >> "$SESSION_FILE"
    echo "" >> "$SESSION_FILE"
fi

# 追加提交记录
echo "## Commit: $COMMIT_HASH" >> "$SESSION_FILE"
echo "**时间**: $COMMIT_TIME" >> "$SESSION_FILE"
echo "**作者**: $COMMIT_AUTHOR" >> "$SESSION_FILE"
echo "" >> "$SESSION_FILE"
echo '```' >> "$SESSION_FILE"
echo "$COMMIT_MSG" >> "$SESSION_FILE"
echo '```' >> "$SESSION_FILE"
echo "" >> "$SESSION_FILE"
echo "---" >> "$SESSION_FILE"
echo "" >> "$SESSION_FILE"

echo "✅ 已记录提交 $COMMIT_HASH 到 SESSION.md"
